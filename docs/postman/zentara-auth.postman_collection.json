{
  "info": {
    "_postman_id": "758973f5-6a4a-49ff-8d68-3f18f9ab818f",
    "name": "ZENTARA Auth API",
    "description": "Reviewer-facing walkthrough of the ZENTARA auth API. Select the \"ZENTARA Auth \u2014 Staging\" environment and run the folders top-to-bottom (Collection Runner) or click through in order. Tokens are captured automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Health",
      "item": [
        {
          "name": "Liveness (/livez)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livez",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livez"
              ]
            },
            "description": "Process-alive check. No dependencies."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Readiness (/readyz)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/readyz",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "readyz"
              ]
            },
            "description": "Checks DB + Redis reachability."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"db and redis are ok\", function () {",
                  "  var c = pm.response.json().checks;",
                  "  pm.expect(c.db).to.eql(\"ok\");",
                  "  pm.expect(c.redis).to.eql(\"ok\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Auth lifecycle",
      "item": [
        {
          "name": "Register (new Viewer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a fresh Viewer account. A unique email is generated per run.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set(\"email\", \"reviewer+\" + Date.now() + \"@example.com\");",
                  "pm.environment.set(\"password\", \"ReviewerPass123!\");"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 201\", function () { pm.response.to.have.status(201); });",
                  "var u = pm.response.json();",
                  "pm.environment.set(\"user_id\", u.id);",
                  "pm.test(\"default role is viewer\", function () { pm.expect(u.role).to.eql(\"viewer\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticates and returns the JWT access + refresh pair (captured into the environment).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.environment.set(\"access_token\", j.access_token);",
                  "pm.environment.set(\"refresh_token\", j.refresh_token);",
                  "pm.test(\"returns an access token\", function () {",
                  "  pm.expect(j.access_token, \"access_token\").to.be.a(\"string\").and.to.have.length.above(10);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get profile (/auth/me) \u2014 cache MISS",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "First read populates the per-user Redis cache; note the X-Cache: MISS response header."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "console.log(\"X-Cache:\", pm.response.headers.get(\"X-Cache\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get profile again \u2014 cache HIT",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Second read is served from cache (X-Cache: HIT) within CACHE_TTL."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"served from cache (X-Cache: HIT)\", function () {",
                  "  pm.expect(pm.response.headers.get(\"X-Cache\")).to.eql(\"HIT\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh tokens",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Rotates the pair. The previous refresh token is revoked; the new pair is re-captured.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.environment.set(\"access_token\", j.access_token);",
                  "pm.environment.set(\"refresh_token\", j.refresh_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Revokes the refresh token (returns 204). The access token remains valid until it expires.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 204\", function () { pm.response.to.have.status(204); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. RBAC proof (Viewer denied)",
      "item": [
        {
          "name": "Viewer hits /admin/users \u2192 403",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users"
              ]
            },
            "description": "The Viewer token from folder 2 is rejected by role-based access control."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"viewer is forbidden (403)\", function () { pm.response.to.have.status(403); });",
                  "pm.test(\"error code is FORBIDDEN\", function () {",
                  "  pm.expect(pm.response.json().error.code).to.eql(\"FORBIDDEN\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Admin + AI threat analysis",
      "item": [
        {
          "name": "Admin login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in as the bootstrapped admin. Requires BOOTSTRAP_ADMIN_EMAIL/PASSWORD set on the server (same values as admin_email/admin_password here).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"admin login 200 (needs BOOTSTRAP_ADMIN_* on server)\", function () { pm.response.to.have.status(200); });",
                  "pm.environment.set(\"admin_access_token\", pm.response.json().access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "List users (admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users"
              ]
            },
            "description": "Admin-only listing of all users."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"returns a users array\", function () {",
                  "  pm.expect(pm.response.json().users).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "AI threat summary for the Viewer",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/threat-summary",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users",
                "{{user_id}}",
                "threat-summary"
              ]
            },
            "description": "LLM-generated risk assessment for the user registered in folder 2. Returns 503 if the self-hosted model is cold or disabled."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200 or 503 (LLM may be cold/disabled)\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});",
                  "if (pm.response.code === 200) { console.log(\"Assessment:\", pm.response.json().assessment); }"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
