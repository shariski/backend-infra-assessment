APP_PORT=8080
APP_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth
DB_SSLMODE=disable

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_DB=0

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_WINDOW=15m

LOG_LEVEL=info

# Response cache TTL for GET /auth/me and GET /admin/users.
# Backed by Redis; failures degrade to direct handler invocation.
CACHE_TTL=60s

# --- Local LLM (Ollama) threat analysis — optional bonus feature ---
# Powers GET /admin/users/:id/threat-summary. Leave OLLAMA_URL empty to disable
# (the endpoint then returns 503). For local dev, start Ollama and pull the model:
#   docker compose --profile llm up -d ollama
#   docker compose --profile llm exec ollama ollama pull llama3.2:1b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=30s

# Cloudflare Access service token for the VPS-hosted Ollama (cluster only; blank locally).
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Threat-summary cache TTL and how many recent rows feed the model.
LLM_SUMMARY_TTL=5m
LLM_MAX_ATTEMPTS=20
LLM_MAX_EVENTS=20
